interface bitemporal-float-ops {
    use types.{timestamp-tz, time-period, temporal-error};

    record bitemporal-float-instant {
        value: f64,
        valid-start: s64,
        valid-end: s64,
        transaction-start: s64,
        transaction-end: s64,
    }
    record bitemporal-float-sequence {
        instants: list<bitemporal-float-instant>,
    }

    bitemporal-float-instant-new: func(value: f64, valid-start: s64, valid-end: s64, transaction-start: s64, transaction-end: s64) -> bitemporal-float-instant;
    bitemporal-float-sequence-new: func(instants: list<bitemporal-float-instant>) -> bitemporal-float-sequence;
    bitemporal-float-len: func(seq: bitemporal-float-sequence) -> u32;

    bitemporal-float-valid-at: func(seq: bitemporal-float-sequence, valid-ts: s64) -> option<f64>;
    bitemporal-float-as-of: func(seq: bitemporal-float-sequence, valid-ts: s64, transaction-ts: s64) -> option<f64>;
    bitemporal-float-count-current: func(seq: bitemporal-float-sequence) -> u32;
    bitemporal-float-count-superseded: func(seq: bitemporal-float-sequence) -> u32;
    bitemporal-float-current-values: func(seq: bitemporal-float-sequence) -> list<f64>;
    bitemporal-float-all-values: func(seq: bitemporal-float-sequence) -> list<f64>;
    bitemporal-float-valid-extent: func(seq: bitemporal-float-sequence) -> option<time-period>;
    bitemporal-float-transaction-extent: func(seq: bitemporal-float-sequence) -> option<time-period>;

    bitemporal-float-is-valid-at: func(inst: bitemporal-float-instant, ts: s64) -> bool;
    bitemporal-float-was-known-at: func(inst: bitemporal-float-instant, ts: s64) -> bool;
    bitemporal-float-is-current: func(inst: bitemporal-float-instant) -> bool;
    bitemporal-float-valid-duration: func(inst: bitemporal-float-instant) -> s64;
    bitemporal-float-transaction-duration: func(inst: bitemporal-float-instant) -> s64;

    /// W7: text codecs.
    bitemporal-float-to-ewkt:   func(seq: bitemporal-float-sequence) -> string;
    bitemporal-float-from-ewkt: func(s: string) -> option<bitemporal-float-sequence>;
}

interface bitemporal-int-ops {
    use types.{timestamp-tz, time-period, temporal-error};

    record bitemporal-int-instant {
        value: s64,
        valid-start: s64,
        valid-end: s64,
        transaction-start: s64,
        transaction-end: s64,
    }
    record bitemporal-int-sequence {
        instants: list<bitemporal-int-instant>,
    }

    bitemporal-int-instant-new: func(value: s64, valid-start: s64, valid-end: s64, transaction-start: s64, transaction-end: s64) -> bitemporal-int-instant;
    bitemporal-int-sequence-new: func(instants: list<bitemporal-int-instant>) -> bitemporal-int-sequence;
    bitemporal-int-len: func(seq: bitemporal-int-sequence) -> u32;

    bitemporal-int-valid-at: func(seq: bitemporal-int-sequence, valid-ts: s64) -> option<s64>;
    bitemporal-int-as-of: func(seq: bitemporal-int-sequence, valid-ts: s64, transaction-ts: s64) -> option<s64>;
    bitemporal-int-count-current: func(seq: bitemporal-int-sequence) -> u32;
    bitemporal-int-count-superseded: func(seq: bitemporal-int-sequence) -> u32;
    bitemporal-int-current-values: func(seq: bitemporal-int-sequence) -> list<s64>;
    bitemporal-int-all-values: func(seq: bitemporal-int-sequence) -> list<s64>;
    bitemporal-int-valid-extent: func(seq: bitemporal-int-sequence) -> option<time-period>;
    bitemporal-int-transaction-extent: func(seq: bitemporal-int-sequence) -> option<time-period>;

    bitemporal-int-is-valid-at: func(inst: bitemporal-int-instant, ts: s64) -> bool;
    bitemporal-int-was-known-at: func(inst: bitemporal-int-instant, ts: s64) -> bool;
    bitemporal-int-is-current: func(inst: bitemporal-int-instant) -> bool;
    bitemporal-int-valid-duration: func(inst: bitemporal-int-instant) -> s64;
    bitemporal-int-transaction-duration: func(inst: bitemporal-int-instant) -> s64;

    /// W7: text codecs. Format: `value@[vs,ve)@[ts,te)` per instant,
    /// outer brackets around the sequence.
    bitemporal-int-to-ewkt:   func(seq: bitemporal-int-sequence) -> string;
    bitemporal-int-from-ewkt: func(s: string) -> option<bitemporal-int-sequence>;
}

interface tgeogpoint-ops {
    use types.{timestamp-tz, time-period, tfloat-sequence, temporal-error};

    record geog-point { lon: f64, lat: f64 }
    record tgeogpoint-instant { timestamp: timestamp-tz, point: geog-point }
    record tgeogpoint-sequence {
        instants: list<tgeogpoint-instant>,
        lower-inclusive: bool,
        upper-inclusive: bool,
    }

    tgeogpoint-instant-new: func(t: timestamp-tz, lon: f64, lat: f64) -> tgeogpoint-instant;
    tgeogpoint-sequence-new: func(instants: list<tgeogpoint-instant>) -> result<tgeogpoint-sequence, temporal-error>;
    tgeogpoint-num-instants: func(seq: tgeogpoint-sequence) -> u32;
    tgeogpoint-lon-at: func(seq: tgeogpoint-sequence, t: timestamp-tz) -> option<f64>;
    tgeogpoint-lat-at: func(seq: tgeogpoint-sequence, t: timestamp-tz) -> option<f64>;
    tgeogpoint-length-geodetic: func(seq: tgeogpoint-sequence) -> f64;
    tgeogpoint-avg-speed-geodetic: func(seq: tgeogpoint-sequence) -> option<f64>;
    tgeogpoint-min-distance: func(seq1: tgeogpoint-sequence, seq2: tgeogpoint-sequence) -> option<f64>;
    tgeogpoint-distance-to-point: func(seq: tgeogpoint-sequence, lon: f64, lat: f64) -> option<f64>;
    tgeogpoint-azimuth-at: func(seq: tgeogpoint-sequence, t: timestamp-tz) -> option<f64>;
    tgeogpoint-speed-at: func(seq: tgeogpoint-sequence, t: timestamp-tz) -> option<f64>;
    tgeogpoint-time-span: func(seq: tgeogpoint-sequence) -> option<time-period>;

    /// W10: per-instant geodetic predicates (Haversine).
    /// True if any instant is within `distance-m` meters of (lon,lat).
    tgeogpoint-dwithin-point-geodetic: func(
        seq: tgeogpoint-sequence,
        lon: f64,
        lat: f64,
        distance-m: f64,
    ) -> bool;

    /// True if all instants are within `distance-m` of (lon,lat).
    tgeogpoint-always-dwithin-point-geodetic: func(
        seq: tgeogpoint-sequence,
        lon: f64,
        lat: f64,
        distance-m: f64,
    ) -> bool;

    /// Sequence of per-instant great-circle distances (meters)
    /// from each instant to a fixed (lon, lat). Returns Stepwise
    /// tfloat-sequence with duplicated-last semantics.
    tgeogpoint-distance-to-point-seq: func(
        seq: tgeogpoint-sequence,
        lon: f64,
        lat: f64,
    ) -> option<tfloat-sequence>;

    /// X5 (geodetic completion): true if any instant equals
    /// (lon,lat) within `epsilon-m` meters.
    tgeogpoint-tintersects-point-geodetic: func(
        seq: tgeogpoint-sequence,
        lon: f64,
        lat: f64,
        epsilon-m: f64,
    ) -> bool;
    /// Inverse: true if NO instant is within `epsilon-m` of (lon,lat).
    tgeogpoint-tdisjoint-point-geodetic: func(
        seq: tgeogpoint-sequence,
        lon: f64,
        lat: f64,
        epsilon-m: f64,
    ) -> bool;
    /// Minimum great-circle distance from sequence to a fixed point (meters).
    tgeogpoint-min-distance-to-point-geodetic: func(
        seq: tgeogpoint-sequence,
        lon: f64,
        lat: f64,
    ) -> option<f64>;
    /// Maximum great-circle distance from sequence to a fixed point (meters).
    tgeogpoint-max-distance-to-point-geodetic: func(
        seq: tgeogpoint-sequence,
        lon: f64,
        lat: f64,
    ) -> option<f64>;
}

interface tgeometry-ops {
    use types.{timestamp-tz, time-period, temporal-error};

    /// A geometry sample reduced to its centroid + classification
    /// metadata. Phase-7 codec only handles point-only sequences; the
    /// host stores 24 bytes per instant (i64 t + 2×f64 centroid).
    record tgeometry-point-instant { timestamp: timestamp-tz, x: f64, y: f64 }
    record tgeometry-point-sequence {
        instants: list<tgeometry-point-instant>,
        lower-inclusive: bool,
        upper-inclusive: bool,
    }

    tgeometry-point-instant-new: func(t: timestamp-tz, x: f64, y: f64) -> tgeometry-point-instant;
    tgeometry-point-num-instants: func(seq: tgeometry-point-sequence) -> u32;
    tgeometry-point-min-distance-to-point: func(seq: tgeometry-point-sequence, x: f64, y: f64) -> f64;
    tgeometry-point-min-distance: func(seq1: tgeometry-point-sequence, seq2: tgeometry-point-sequence) -> f64;
    tgeometry-point-time-span: func(seq: tgeometry-point-sequence) -> option<time-period>;
}

/// Nearest-neighbour temporal join (W4a #557)
///
/// For each instant in `left`, finds the nearest-in-time instant in
/// `right` and emits a row `(timestamp, distance, left, right)`. The
/// `distance` field is the absolute time difference in microseconds
/// rendered as `f64` so callers can use it as a Real-affinity column.
///
/// Cross-project coordination note: the upstream `mobilitydb-wasm`
/// implementation is the source of truth for the precise nearest-
/// neighbour semantics (forward-only, backward-only, both, ...).
/// These declarations pick the canonical "both, returning the closer
/// of the two candidates" shape; if the implementation diverges, the
/// row shape stays valid and the join semantics resolve upstream.
interface nearest-join-ops {
    use types.{timestamp-tz, tfloat-sequence, tint-sequence};
    use ttext-ops.{ttext-sequence};
    use tbool-ops.{tbool-sequence};

    record nearest-bool-pair {
        timestamp: timestamp-tz,
        distance: f64,
        left: bool,
        right: bool,
    }

    record nearest-float-pair {
        timestamp: timestamp-tz,
        distance: f64,
        left: f64,
        right: f64,
    }

    record nearest-int-pair {
        timestamp: timestamp-tz,
        distance: f64,
        left: s64,
        right: s64,
    }

    record nearest-text-pair {
        timestamp: timestamp-tz,
        distance: f64,
        left: string,
        right: string,
    }

    nearest-join-bool: func(left: tbool-sequence, right: tbool-sequence) -> list<nearest-bool-pair>;
    nearest-join-float: func(left: tfloat-sequence, right: tfloat-sequence) -> list<nearest-float-pair>;
    nearest-join-int: func(left: tint-sequence, right: tint-sequence) -> list<nearest-int-pair>;
    nearest-join-text: func(left: ttext-sequence, right: ttext-sequence) -> list<nearest-text-pair>;
}

/// Time-bucketed split of a temporal sequence (W4a #557)
///
/// Splits a sequence into sub-sequences whose timestamps fall into
/// successive `[bucket-start, bucket-end)` windows. Each row's
/// `sub-sequence-json` field carries the JSON encoding of the sub-
/// sequence — same format as `tfloat-to-json` / `tint-to-json` — so
/// callers can re-parse it via SQLite's JSON1 ops. Picking JSON over
/// a nested record keeps each row table-shaped (three primitive
/// columns) and aligns with the W3.4 `RetShape::JsonText` choice.
///
/// Param shape `(seq, bucket-size, origin)` mirrors mobilitydb's
/// PostgreSQL surface for `*_time_split`. The interface DB lists
/// `(binary, int64, int64)` matching that shape.
interface time-split-ops {
    use types.{timestamp-tz, tfloat-sequence, tint-sequence};

    record tfloat-time-bucket {
        bucket-start: timestamp-tz,
        bucket-end: timestamp-tz,
        sub-sequence-json: string,
    }

    record tint-time-bucket {
        bucket-start: timestamp-tz,
        bucket-end: timestamp-tz,
        sub-sequence-json: string,
    }

    tfloat-time-split: func(seq: tfloat-sequence, bucket-size: s64, origin: s64) -> list<tfloat-time-bucket>;
    tint-time-split: func(seq: tint-sequence, bucket-size: s64, origin: s64) -> list<tint-time-bucket>;
}

/// Value-bucketed split of a temporal sequence (W4a #557)
///
/// Sibling of `time-split-ops` but bucketing on the value axis. For
/// `tfloat-value-split` the interface DB lists `(binary, float64,
/// float64)`; for `tint-value-split` it lists `(binary, int64,
/// int64)`. The row shape carries the bucket bounds (typed to match
/// the element type) and the same JSON-encoded sub-sequence.
interface value-split-ops {
    use types.{tfloat-sequence, tint-sequence};

    record tfloat-value-bucket {
        bucket-lower: f64,
        bucket-upper: f64,
        sub-sequence-json: string,
    }

    record tint-value-bucket {
        bucket-lower: s64,
        bucket-upper: s64,
        sub-sequence-json: string,
    }

    tfloat-value-split: func(seq: tfloat-sequence, bucket-size: f64, origin: f64) -> list<tfloat-value-bucket>;
    tint-value-split: func(seq: tint-sequence, bucket-size: s64, origin: s64) -> list<tint-value-bucket>;
}

/// Per-instant projection of a temporal sequence (W4a #557)
///
/// Each `*-to-rows` UDTF emits one row per instant in the input
/// sequence, with the row carrying the timestamp plus the typed
/// coordinate fields. Row shapes are all-primitive so the W4b row
/// materialiser projects them directly without needing wit-value.
///
/// Cross-project coordination note: the upstream signature for each
/// `*-to-rows` is fixed by the underlying temporal point/pose/
/// cbuffer type. These declarations make the row schema explicit so
/// the SQL surface can SELECT individual coordinate columns.
interface to-rows-ops {
    use types.{timestamp-tz, tgeompoint-sequence};
    use tgeompoint3d-ops.{tgeompoint3d-sequence};
    use tgeogpoint-ops.{tgeogpoint-sequence};
    use tpose-ops.{tpose-sequence};
    use tcbuffer-ops.{tcbuffer-sequence};

    record tgeompoint-row {
        timestamp: timestamp-tz,
        x: f64,
        y: f64,
    }

    record tgeompoint3d-row {
        timestamp: timestamp-tz,
        x: f64,
        y: f64,
        z: f64,
    }

    record tgeogpoint-row {
        timestamp: timestamp-tz,
        lon: f64,
        lat: f64,
    }

    record tpose-row {
        timestamp: timestamp-tz,
        x: f64,
        y: f64,
        orientation: f64,
    }

    record tcbuffer-row {
        timestamp: timestamp-tz,
        x: f64,
        y: f64,
        radius: f64,
    }

    tgeompoint-to-rows: func(seq: tgeompoint-sequence) -> list<tgeompoint-row>;
    tgeompoint3d-to-rows: func(seq: tgeompoint3d-sequence) -> list<tgeompoint3d-row>;
    tgeogpoint-to-rows: func(seq: tgeogpoint-sequence) -> list<tgeogpoint-row>;
    tpose-to-rows: func(seq: tpose-sequence) -> list<tpose-row>;
    tcbuffer-to-rows: func(seq: tcbuffer-sequence) -> list<tcbuffer-row>;
}

/// Temporal-index lookups (W4a #557)
///
/// Lightweight per-instant matches against a temporal sequence
/// (treated as an implicit index over its instant array). Each row
/// carries `(instant-index, timestamp)` — both Integer-affinity
/// columns. The five variants cover point lookup (`find-at`),
/// directional scans (`find-after`, `find-before`), and range
/// overlaps (`find-in-range`, `find-overlapping`).
///
/// Cross-project coordination note: the interface DB lists every
/// variant as taking `(binary, int64[, int64])`. We canonicalise
/// `binary` to `tfloat-sequence` here — the upstream impl may
/// generalise to any temporal type, in which case the binary will
/// still round-trip through wit-value (mobilitydb's record codecs
/// produce structurally-identical bytes per record type). If
/// callers pass a non-tfloat binary the WIT decoder will surface
/// the mismatch at the host boundary.
interface temporal-index-ops {
    use types.{timestamp-tz, tfloat-sequence};

    record temporal-index-match {
        instant-index: u32,
        timestamp: timestamp-tz,
    }

    temporal-index-find-at: func(seq: tfloat-sequence, t: timestamp-tz) -> list<temporal-index-match>;
    temporal-index-find-after: func(seq: tfloat-sequence, t: timestamp-tz) -> list<temporal-index-match>;
    temporal-index-find-before: func(seq: tfloat-sequence, t: timestamp-tz) -> list<temporal-index-match>;
    temporal-index-find-in-range: func(seq: tfloat-sequence, t-lower: timestamp-tz, t-upper: timestamp-tz) -> list<temporal-index-match>;
    temporal-index-find-overlapping: func(seq: tfloat-sequence, t-lower: timestamp-tz, t-upper: timestamp-tz) -> list<temporal-index-match>;
}

/// Spatial-index lookups (W4a #557)
///
/// Per-instant spatial matches against a `tgeompoint-sequence`. Row
/// shape carries the instant index, the (x, y) coordinates of the
/// matched instant, and a `distance` field measured in CRS units
/// (matching the input's frame — no geodetic adjustment).
///
/// `find-in-envelope` takes a bounding box `(min-x, min-y, max-x,
/// max-y)`; `find-within-distance` takes `(cx, cy, radius)`;
/// `nearest` takes `(cx, cy)` and returns the single closest
/// instant; `nearest-k` adds a `k: s32` cap.
interface spatial-index-ops {
    use types.{timestamp-tz, tgeompoint-sequence};

    record spatial-index-match {
        instant-index: u32,
        timestamp: timestamp-tz,
        x: f64,
        y: f64,
        distance: f64,
    }

    spatial-index-find-in-envelope: func(
        seq: tgeompoint-sequence,
        min-x: f64,
        min-y: f64,
        max-x: f64,
        max-y: f64,
    ) -> list<spatial-index-match>;
    spatial-index-find-within-distance: func(
        seq: tgeompoint-sequence,
        cx: f64,
        cy: f64,
        radius: f64,
    ) -> list<spatial-index-match>;
    spatial-index-nearest: func(
        seq: tgeompoint-sequence,
        cx: f64,
        cy: f64,
    ) -> list<spatial-index-match>;
    spatial-index-nearest-k: func(
        seq: tgeompoint-sequence,
        cx: f64,
        cy: f64,
        k: s32,
    ) -> list<spatial-index-match>;
}

/// Sequence → JSON degenerate UDTF (W4a #557)
///
/// `sequence-json` takes a single temporal sequence and emits a
/// single row carrying `(seq-id, json)`. The `seq-id` is a stable
/// zero-based identifier (always 0 for single-sequence input,
/// reserved for future batched extension); the `json` field is the
/// `tfloat-to-json`-shaped encoding. The UDTF shape (rather than a
/// scalar text returns) keeps this addressable by name in the SQL
/// surface alongside the other index/join UDTFs.
interface sequence-json-ops {
    use types.{tfloat-sequence};

    record sequence-json-row {
        seq-id: u32,
        json: string,
    }

    sequence-json: func(seq: tfloat-sequence) -> list<sequence-json-row>;
}

