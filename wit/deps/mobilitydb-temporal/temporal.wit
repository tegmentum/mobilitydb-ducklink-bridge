    bitemporal-text-sequence-new: func(instants: list<bitemporal-text-instant>) -> bitemporal-text-sequence;
    bitemporal-text-len: func(seq: bitemporal-text-sequence) -> u32;

    bitemporal-text-valid-at: func(seq: bitemporal-text-sequence, valid-ts: s64) -> option<string>;
    bitemporal-text-as-of: func(seq: bitemporal-text-sequence, valid-ts: s64, transaction-ts: s64) -> option<string>;
    bitemporal-text-count-current: func(seq: bitemporal-text-sequence) -> u32;
    bitemporal-text-count-superseded: func(seq: bitemporal-text-sequence) -> u32;
