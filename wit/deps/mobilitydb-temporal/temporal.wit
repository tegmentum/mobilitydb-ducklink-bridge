    tcbuffer-always-contains-point: func(seq: tcbuffer-sequence, x: f64, y: f64) -> bool;
    tcbuffer-contains-point-at: func(seq: tcbuffer-sequence, x: f64, y: f64, t: s64) -> bool;
    tcbuffer-get-center-x: func(seq: tcbuffer-sequence) -> tfloat-sequence;
    tcbuffer-get-center-y: func(seq: tcbuffer-sequence) -> tfloat-sequence;
    tcbuffer-get-radius: func(seq: tcbuffer-sequence) -> tfloat-sequence;
    tcbuffer-get-area: func(seq: tcbuffer-sequence) -> tfloat-sequence;
    tcbuffer-to-tgeompoint: func(seq: tcbuffer-sequence) -> tgeompoint-sequence;
}

interface tpose-extended-ops {
    use types.{tfloat-sequence, tgeompoint-sequence};
    use tpose-ops.{tpose-sequence};

    tpose-get-x: func(seq: tpose-sequence) -> tfloat-sequence;
    tpose-get-y: func(seq: tpose-sequence) -> tfloat-sequence;
    tpose-get-orientation: func(seq: tpose-sequence) -> tfloat-sequence;
    tpose-linear-speed: func(seq: tpose-sequence) -> tfloat-sequence;
    tpose-angular-velocity: func(seq: tpose-sequence) -> tfloat-sequence;
    tpose-linear-acceleration: func(seq: tpose-sequence) -> tfloat-sequence;
    tpose-angular-acceleration: func(seq: tpose-sequence) -> tfloat-sequence;
    tpose-curvature: func(seq: tpose-sequence) -> tfloat-sequence;
    tpose-compute-heading-from-movement: func(seq: tpose-sequence) -> tfloat-sequence;
    tpose-distance-to-point: func(seq: tpose-sequence, px: f64, py: f64) -> tfloat-sequence;
    tpose-distance-to-pose: func(seq1: tpose-sequence, seq2: tpose-sequence) -> tfloat-sequence;
    tpose-angular-distance-to-pose: func(seq1: tpose-sequence, seq2: tpose-sequence) -> tfloat-sequence;
}

interface trajectory-restrictions-ops {
    use types.{tgeompoint-sequence};
    use tgeompoint3d-ops.{tgeompoint3d-sequence};
    use tgeogpoint-ops.{tgeogpoint-sequence};
    use stbox-ops.{stbox};

    // Tgeompoint (2D) point-based restrictions
    tgeompoint-at-point: func(seq: tgeompoint-sequence, x: f64, y: f64, tolerance: f64) -> option<tgeompoint-sequence>;
    tgeompoint-minus-point: func(seq: tgeompoint-sequence, x: f64, y: f64, tolerance: f64) -> option<tgeompoint-sequence>;
    tgeompoint-at-stbox: func(seq: tgeompoint-sequence, box: stbox) -> option<tgeompoint-sequence>;
    tgeompoint-minus-stbox: func(seq: tgeompoint-sequence, box: stbox) -> option<tgeompoint-sequence>;
    tgeompoint-nearest-approach-distance: func(seq1: tgeompoint-sequence, seq2: tgeompoint-sequence) -> option<f64>;

    // Tgeompoint3d (point-only restrictions; 3D STBox restrictions deferred)
    tgeompoint3d-at-point: func(seq: tgeompoint3d-sequence, x: f64, y: f64, z: f64, tolerance: f64) -> option<tgeompoint3d-sequence>;
    tgeompoint3d-minus-point: func(seq: tgeompoint3d-sequence, x: f64, y: f64, z: f64, tolerance: f64) -> option<tgeompoint3d-sequence>;

    // Tgeogpoint
    tgeogpoint-at-stbox: func(seq: tgeogpoint-sequence, box: stbox) -> option<tgeogpoint-sequence>;
    tgeogpoint-minus-stbox: func(seq: tgeogpoint-sequence, box: stbox) -> option<tgeogpoint-sequence>;
}

interface sets-extended-ops {
    // Pack/unpack sets as Binary blobs: u32 count + count × element bytes.

    // IntSet operations
    intset-union: func(a: list<s64>, b: list<s64>) -> list<s64>;
    intset-intersection: func(a: list<s64>, b: list<s64>) -> list<s64>;
    intset-minus: func(a: list<s64>, b: list<s64>) -> list<s64>;
    intset-is-subset: func(a: list<s64>, b: list<s64>) -> bool;
    intset-is-disjoint: func(a: list<s64>, b: list<s64>) -> bool;

    // FloatSet operations
    floatset-union: func(a: list<f64>, b: list<f64>) -> list<f64>;
    floatset-intersection: func(a: list<f64>, b: list<f64>) -> list<f64>;
    floatset-minus: func(a: list<f64>, b: list<f64>) -> list<f64>;
    floatset-is-subset: func(a: list<f64>, b: list<f64>) -> bool;
    floatset-is-disjoint: func(a: list<f64>, b: list<f64>) -> bool;

    // TextSet operations
    textset-union: func(a: list<string>, b: list<string>) -> list<string>;
    textset-intersection: func(a: list<string>, b: list<string>) -> list<string>;
    textset-minus: func(a: list<string>, b: list<string>) -> list<string>;
    textset-is-subset: func(a: list<string>, b: list<string>) -> bool;
    textset-is-disjoint: func(a: list<string>, b: list<string>) -> bool;
}

interface ttext-strings-ops {
    use types.{tint-sequence};
    use ttext-ops.{ttext-sequence};
    use tbool-ops.{tbool-sequence};

    ttext-upper: func(seq: ttext-sequence) -> ttext-sequence;
    ttext-lower: func(seq: ttext-sequence) -> ttext-sequence;
    ttext-length: func(seq: ttext-sequence) -> tint-sequence;
    ttext-concat: func(seq1: ttext-sequence, seq2: ttext-sequence) -> option<ttext-sequence>;
    ttext-concat-str: func(seq: ttext-sequence, suffix: string) -> ttext-sequence;
    ttext-prepend-str: func(prefix: string, seq: ttext-sequence) -> ttext-sequence;
    ttext-like: func(seq: ttext-sequence, pattern: string) -> tbool-sequence;
    ttext-ilike: func(seq: ttext-sequence, pattern: string) -> tbool-sequence;
    ttext-regex-match: func(seq: ttext-sequence, pattern: string) -> tbool-sequence;
    ttext-regex-replace: func(seq: ttext-sequence, pattern: string, replacement: string) -> ttext-sequence;
    ttext-left: func(seq: ttext-sequence, n: u32) -> ttext-sequence;
    ttext-right: func(seq: ttext-sequence, n: u32) -> ttext-sequence;
    ttext-ltrim: func(seq: ttext-sequence) -> ttext-sequence;
    ttext-rtrim: func(seq: ttext-sequence) -> ttext-sequence;
    ttext-btrim: func(seq: ttext-sequence) -> ttext-sequence;
}

interface statistics-ops {
    use types.{tfloat-sequence, tint-sequence, timestamp-tz};

    // Single-sequence calculus
    tfloat-integral: func(seq: tfloat-sequence) -> f64;
    tfloat-derivative: func(seq: tfloat-sequence) -> option<tfloat-sequence>;
    tfloat-sample-entropy: func(seq: tfloat-sequence, m: u32, r: f64) -> option<f64>;

    // Pairwise rolling statistics
    tfloat-temporal-correlation: func(seq1: tfloat-sequence, seq2: tfloat-sequence, window-size: u32) -> option<tfloat-sequence>;
    tfloat-temporal-covariance: func(seq1: tfloat-sequence, seq2: tfloat-sequence, window-size: u32) -> option<tfloat-sequence>;
    tfloat-correlation-at: func(sequences: list<tfloat-sequence>, ts: timestamp-tz) -> option<f64>;

    // Multi-sequence statistics
    tfloat-temporal-mode: func(sequences: list<tfloat-sequence>, bin-width: f64) -> option<tfloat-sequence>;
    tfloat-temporal-range: func(sequences: list<tfloat-sequence>) -> option<tfloat-sequence>;
    tfloat-temporal-iqr: func(sequences: list<tfloat-sequence>) -> option<tfloat-sequence>;
    tfloat-temporal-skewness: func(sequences: list<tfloat-sequence>) -> option<tfloat-sequence>;
    tfloat-temporal-kurtosis: func(sequences: list<tfloat-sequence>) -> option<tfloat-sequence>;
    tfloat-temporal-entropy: func(sequences: list<tfloat-sequence>, num-bins: u32) -> option<tfloat-sequence>;
    tfloat-temporal-weighted-median: func(sequences: list<tfloat-sequence>, weights: list<f64>) -> option<tfloat-sequence>;

    tint-temporal-mode: func(sequences: list<tint-sequence>) -> option<tint-sequence>;
    tint-temporal-range: func(sequences: list<tint-sequence>) -> option<tint-sequence>;
}

interface arithmetic-ops {
    use types.{tfloat-sequence, tint-sequence};

    // Tfloat seq-vs-seq arithmetic
    tfloat-add: func(seq1: tfloat-sequence, seq2: tfloat-sequence) -> option<tfloat-sequence>;
    tfloat-sub: func(seq1: tfloat-sequence, seq2: tfloat-sequence) -> option<tfloat-sequence>;
    tfloat-mul: func(seq1: tfloat-sequence, seq2: tfloat-sequence) -> option<tfloat-sequence>;
    tfloat-div: func(seq1: tfloat-sequence, seq2: tfloat-sequence) -> option<tfloat-sequence>;

    // Tfloat seq-vs-scalar
    tfloat-add-scalar: func(seq: tfloat-sequence, v: f64) -> tfloat-sequence;
    tfloat-sub-scalar: func(seq: tfloat-sequence, v: f64) -> tfloat-sequence;
    tfloat-mul-scalar: func(seq: tfloat-sequence, v: f64) -> tfloat-sequence;
    tfloat-div-scalar: func(seq: tfloat-sequence, v: f64) -> option<tfloat-sequence>;

    // Tint seq-vs-seq
    tint-add: func(seq1: tint-sequence, seq2: tint-sequence) -> option<tint-sequence>;
    tint-sub: func(seq1: tint-sequence, seq2: tint-sequence) -> option<tint-sequence>;
    tint-mul: func(seq1: tint-sequence, seq2: tint-sequence) -> option<tint-sequence>;
    tint-div: func(seq1: tint-sequence, seq2: tint-sequence) -> option<tint-sequence>;

    // Tint seq-vs-scalar
    tint-add-scalar: func(seq: tint-sequence, v: s64) -> tint-sequence;
    tint-sub-scalar: func(seq: tint-sequence, v: s64) -> tint-sequence;
    tint-mul-scalar: func(seq: tint-sequence, v: s64) -> tint-sequence;
    tint-div-scalar: func(seq: tint-sequence, v: s64) -> option<tint-sequence>;
}

interface comparisons-ops {
    use types.{tfloat-sequence, tint-sequence};
    use tbool-ops.{tbool-sequence};
    use ttext-ops.{ttext-sequence};

    // Tfloat seq-vs-seq pointwise comparisons.
    tfloat-temporal-eq: func(seq1: tfloat-sequence, seq2: tfloat-sequence) -> option<tbool-sequence>;
    tfloat-temporal-ne: func(seq1: tfloat-sequence, seq2: tfloat-sequence) -> option<tbool-sequence>;
    tfloat-temporal-lt: func(seq1: tfloat-sequence, seq2: tfloat-sequence) -> option<tbool-sequence>;
    tfloat-temporal-le: func(seq1: tfloat-sequence, seq2: tfloat-sequence) -> option<tbool-sequence>;
    tfloat-temporal-gt: func(seq1: tfloat-sequence, seq2: tfloat-sequence) -> option<tbool-sequence>;
    tfloat-temporal-ge: func(seq1: tfloat-sequence, seq2: tfloat-sequence) -> option<tbool-sequence>;

    // Tint seq-vs-seq pointwise comparisons.
    tint-temporal-eq: func(seq1: tint-sequence, seq2: tint-sequence) -> option<tbool-sequence>;
    tint-temporal-ne: func(seq1: tint-sequence, seq2: tint-sequence) -> option<tbool-sequence>;
    tint-temporal-lt: func(seq1: tint-sequence, seq2: tint-sequence) -> option<tbool-sequence>;
    tint-temporal-le: func(seq1: tint-sequence, seq2: tint-sequence) -> option<tbool-sequence>;
    tint-temporal-gt: func(seq1: tint-sequence, seq2: tint-sequence) -> option<tbool-sequence>;
    tint-temporal-ge: func(seq1: tint-sequence, seq2: tint-sequence) -> option<tbool-sequence>;

    // Tfloat ever/always (derived from seq-vs-scalar lifted predicates).
    tfloat-ever-eq:    func(seq: tfloat-sequence, v: f64) -> bool;
    tfloat-always-eq:  func(seq: tfloat-sequence, v: f64) -> bool;
    tfloat-ever-lt:    func(seq: tfloat-sequence, v: f64) -> bool;
    tfloat-always-lt:  func(seq: tfloat-sequence, v: f64) -> bool;
    tfloat-ever-gt:    func(seq: tfloat-sequence, v: f64) -> bool;
    tfloat-always-gt:  func(seq: tfloat-sequence, v: f64) -> bool;

    // Tint ever/always.
    tint-ever-eq:    func(seq: tint-sequence, v: s64) -> bool;
    tint-always-eq:  func(seq: tint-sequence, v: s64) -> bool;
    tint-ever-lt:    func(seq: tint-sequence, v: s64) -> bool;
    tint-always-lt:  func(seq: tint-sequence, v: s64) -> bool;
    tint-ever-gt:    func(seq: tint-sequence, v: s64) -> bool;
    tint-always-gt:  func(seq: tint-sequence, v: s64) -> bool;

    // Ttext ever/always equality.
    ttext-ever-eq:    func(seq: ttext-sequence, v: string) -> bool;
    ttext-always-eq:  func(seq: ttext-sequence, v: string) -> bool;
}

interface restrictions-ops {
    use types.{tfloat-sequence, tint-sequence, time-period};
    use tbool-ops.{tbool-sequence};
    use ttext-ops.{ttext-sequence};

    // Tfloat restrictions
    tfloat-at-period: func(seq: tfloat-sequence, start: s64, end: s64) -> option<tfloat-sequence>;
    tfloat-minus-period: func(seq: tfloat-sequence, start: s64, end: s64) -> option<tfloat-sequence>;
    tfloat-at-value: func(seq: tfloat-sequence, v: f64) -> option<tfloat-sequence>;
    tfloat-minus-value: func(seq: tfloat-sequence, v: f64) -> option<tfloat-sequence>;
    tfloat-at-min: func(seq: tfloat-sequence) -> option<tfloat-sequence>;
    tfloat-at-max: func(seq: tfloat-sequence) -> option<tfloat-sequence>;
    tfloat-when-eq: func(seq: tfloat-sequence, v: f64) -> option<tbool-sequence>;
    tfloat-when-ne: func(seq: tfloat-sequence, v: f64) -> option<tbool-sequence>;
    tfloat-when-lt: func(seq: tfloat-sequence, v: f64) -> option<tbool-sequence>;
    tfloat-when-le: func(seq: tfloat-sequence, v: f64) -> option<tbool-sequence>;
    tfloat-when-gt: func(seq: tfloat-sequence, v: f64) -> option<tbool-sequence>;
    tfloat-when-ge: func(seq: tfloat-sequence, v: f64) -> option<tbool-sequence>;

    // Tint restrictions
    tint-at-period: func(seq: tint-sequence, start: s64, end: s64) -> option<tint-sequence>;
    tint-minus-period: func(seq: tint-sequence, start: s64, end: s64) -> option<tint-sequence>;
    tint-at-value: func(seq: tint-sequence, v: s64) -> option<tint-sequence>;
    tint-minus-value: func(seq: tint-sequence, v: s64) -> option<tint-sequence>;
    tint-at-min: func(seq: tint-sequence) -> option<tint-sequence>;
    tint-at-max: func(seq: tint-sequence) -> option<tint-sequence>;
    tint-when-eq: func(seq: tint-sequence, v: s64) -> option<tbool-sequence>;
    tint-when-ne: func(seq: tint-sequence, v: s64) -> option<tbool-sequence>;
    tint-when-lt: func(seq: tint-sequence, v: s64) -> option<tbool-sequence>;
    tint-when-le: func(seq: tint-sequence, v: s64) -> option<tbool-sequence>;
    tint-when-gt: func(seq: tint-sequence, v: s64) -> option<tbool-sequence>;
    tint-when-ge: func(seq: tint-sequence, v: s64) -> option<tbool-sequence>;

    // Tbool restrictions (no min/max/lt/gt)
    tbool-at-period: func(seq: tbool-sequence, start: s64, end: s64) -> option<tbool-sequence>;
    tbool-minus-period: func(seq: tbool-sequence, start: s64, end: s64) -> option<tbool-sequence>;
    tbool-at-value: func(seq: tbool-sequence, v: bool) -> option<tbool-sequence>;
    tbool-minus-value: func(seq: tbool-sequence, v: bool) -> option<tbool-sequence>;

    // Ttext restrictions (no min/max/lt/gt — string-typed)
    ttext-at-period: func(seq: ttext-sequence, start: s64, end: s64) -> option<ttext-sequence>;
    ttext-minus-period: func(seq: ttext-sequence, start: s64, end: s64) -> option<ttext-sequence>;
    ttext-at-value: func(seq: ttext-sequence, v: string) -> option<ttext-sequence>;
    ttext-minus-value: func(seq: ttext-sequence, v: string) -> option<ttext-sequence>;
    ttext-when-eq: func(seq: ttext-sequence, v: string) -> option<tbool-sequence>;
    ttext-when-ne: func(seq: ttext-sequence, v: string) -> option<tbool-sequence>;
}

interface temporal-aggregate-ops {
    use types.{tfloat-sequence, tint-sequence};
    use tbool-ops.{tbool-sequence};
    use tgeogpoint-ops.{tgeogpoint-sequence};
    use tnpoint-ops.{tnpoint-sequence};
    use tpose-ops.{tpose-sequence};
    use tcbuffer-ops.{tcbuffer-sequence};
    use tgeompoint-ops.{tgeompoint-sequence};
    use stbox-ops.{stbox};

    /// Element-wise minimum across multiple float sequences at each instant.
    tfloat-temporal-min: func(sequences: list<tfloat-sequence>) -> option<tfloat-sequence>;
    /// Element-wise maximum across multiple float sequences at each instant.
    tfloat-temporal-max: func(sequences: list<tfloat-sequence>) -> option<tfloat-sequence>;
    /// Element-wise sum across multiple float sequences at each instant.
    tfloat-temporal-sum: func(sequences: list<tfloat-sequence>) -> option<tfloat-sequence>;
    /// Element-wise mean across multiple float sequences at each instant.
    tfloat-temporal-avg: func(sequences: list<tfloat-sequence>) -> option<tfloat-sequence>;
    /// Element-wise count of non-null values across multiple sequences.
    tfloat-temporal-count: func(sequences: list<tfloat-sequence>) -> option<tint-sequence>;

    /// Integer temporal aggregates.
    tint-temporal-min: func(sequences: list<tint-sequence>) -> option<tint-sequence>;
    tint-temporal-max: func(sequences: list<tint-sequence>) -> option<tint-sequence>;
    tint-temporal-sum: func(sequences: list<tint-sequence>) -> option<tint-sequence>;

    /// Boolean temporal AND/OR aggregates.
    tbool-temporal-and: func(sequences: list<tbool-sequence>) -> option<tbool-sequence>;
    tbool-temporal-or:  func(sequences: list<tbool-sequence>) -> option<tbool-sequence>;

    /// M6 (2026-06-23) — per-base-type temporal counts. Returns an
    /// integer sequence whose value at each shared timestamp is the
    /// number of input sequences that have a value defined there.
    /// Counts only — not value-channel reductions — because none of
    /// these point/curve/network types carry a scalar ordering that
    /// lifted min/max/sum could use.
    tgeogpoint-temporal-count: func(sequences: list<tgeogpoint-sequence>) -> option<tint-sequence>;
    tnpoint-temporal-count: func(sequences: list<tnpoint-sequence>) -> option<tint-sequence>;
    tpose-temporal-count: func(sequences: list<tpose-sequence>) -> option<tint-sequence>;
    tcbuffer-temporal-count: func(sequences: list<tcbuffer-sequence>) -> option<tint-sequence>;

    /// Audit Item 9 (2026-06-23) — trajectory aggregates over
    /// tgeompoint. `tgeompoint-temporal-centroid` returns a
    /// tgeompoint sequence whose value at each shared timestamp
    /// is the mean (x, y) over all trajectories defined there.
    /// `tgeompoint-st-extent` returns the smallest STBOX
    /// covering every instant of every input trajectory (xmin /
    /// xmax / ymin / ymax / tmin / tmax). Both deliberately omit
    /// the geographic / network / pose / curve base types — those
    /// don't have a meaningful arithmetic mean in (lon, lat) and
    /// need separate per-type math.
    tgeompoint-temporal-centroid: func(sequences: list<tgeompoint-sequence>) -> option<tgeompoint-sequence>;
    tgeompoint-st-extent: func(sequences: list<tgeompoint-sequence>) -> option<stbox>;
    /// Per-base-type tcount also added for tgeompoint to match the
    /// other point types from M6.
    tgeompoint-temporal-count: func(sequences: list<tgeompoint-sequence>) -> option<tint-sequence>;
}

interface clustering-ops {
    use types.{timestamp-tz};
    use tgeompoint-ops.{tgeompoint-sequence};

    /// 2D point with an integer id — the unit of input for the cluster routines.
    record cluster-point { id: u64, x: f64, y: f64 }

    /// Run DBSCAN over the given 2D points and return the count of clusters
    /// excluding noise.
    dbscan-cluster-count: func(points: list<cluster-point>, eps: f64, min-pts: u32) -> u32;

    /// Run k-means over the given 2D points and return its final inertia.
    kmeans-inertia: func(points: list<cluster-point>, k: u32, max-iters: u32, tolerance: f64, seed: u64) -> f64;

    /// Run k-means and return the centroid x-coordinates in cluster order.
    kmeans-centroid-xs: func(points: list<cluster-point>, k: u32, max-iters: u32, tolerance: f64, seed: u64) -> list<f64>;

    /// Run k-means and return the centroid y-coordinates in cluster order.
    kmeans-centroid-ys: func(points: list<cluster-point>, k: u32, max-iters: u32, tolerance: f64, seed: u64) -> list<f64>;

    /// Run DBSCAN over the instants of a tgeompoint trajectory and return the
    /// number of clusters (excluding noise).
    tgeompoint-cluster-count-dbscan: func(seq: tgeompoint-sequence, eps: f64, min-pts: u32) -> u32;
}

interface similarity-extended-ops {
    use tgeompoint-ops.{tgeompoint-sequence};

    /// LCSS distance (Longest Common Subsequence): 0 = identical, 1 = disjoint.
    lcss-distance: func(seq1: tgeompoint-sequence, seq2: tgeompoint-sequence, epsilon: f64, delta: u32) -> f64;
    /// LCSS similarity = 1 − distance.
    lcss-similarity: func(seq1: tgeompoint-sequence, seq2: tgeompoint-sequence, epsilon: f64, delta: u32) -> f64;
    /// EDR distance (Edit Distance on Real sequences).
    edr-distance: func(seq1: tgeompoint-sequence, seq2: tgeompoint-sequence, epsilon: f64) -> f64;
    /// TWED distance (Time-Warp Edit Distance).
    twed-distance: func(seq1: tgeompoint-sequence, seq2: tgeompoint-sequence, lambda: f64, nu: f64) -> f64;
    /// TWED distance normalized by trajectory length.
    twed-distance-normalized: func(seq1: tgeompoint-sequence, seq2: tgeompoint-sequence, lambda: f64, nu: f64) -> f64;
    /// Average Frechet distance (less sensitive to outliers than max).
    average-frechet-distance: func(seq1: tgeompoint-sequence, seq2: tgeompoint-sequence) -> f64;
    /// DTW distance normalized by path length.
    dtw-distance-normalized: func(seq1: tgeompoint-sequence, seq2: tgeompoint-sequence) -> f64;
}

interface analytics-ops {
    use types.{timestamp-tz};
    use tgeompoint-ops.{tgeompoint-sequence};
    use tgeogpoint-ops.{tgeogpoint-sequence};

    /// Count stops in a trajectory (consecutive instants below speed-threshold for at least min-duration µs).
    tgeompoint-num-stops: func(seq: tgeompoint-sequence, speed-threshold: f64, min-duration-us: s64) -> u32;
    /// Count turns where the angle exceeds the threshold (radians).
    tgeompoint-num-turns: func(seq: tgeompoint-sequence, angle-threshold: f64) -> u32;
    /// Count U-turns (angle > 150°).
    tgeompoint-num-u-turns: func(seq: tgeompoint-sequence) -> u32;
    /// Count loops (positions returning within distance-threshold of an earlier position).
    tgeompoint-num-loops: func(seq: tgeompoint-sequence, distance-threshold: f64) -> u32;
    /// Trajectory quality score in [0, 1].
    tgeompoint-quality-score: func(seq: tgeompoint-sequence) -> f64;

    /// Count convoy patterns among multiple trajectories.
    tgeompoint-num-convoys: func(trajectories: list<tgeompoint-sequence>, distance-threshold: f64, min-duration-us: s64, min-size: u32) -> u32;
    /// Count flock patterns among multiple trajectories.
    tgeompoint-num-flocks: func(trajectories: list<tgeompoint-sequence>, distance-threshold: f64, min-size: u32) -> u32;
    /// Count meeting patterns among multiple trajectories.
    tgeompoint-num-meetings: func(trajectories: list<tgeompoint-sequence>, distance-threshold: f64, min-duration-us: s64) -> u32;

    /// Geography variants.
    tgeogpoint-num-stops: func(seq: tgeogpoint-sequence, speed-threshold: f64, min-duration-us: s64) -> u32;
    tgeogpoint-num-turns: func(seq: tgeogpoint-sequence, angle-threshold: f64) -> u32;

    /// Geometric helpers — bearing and distance over Cartesian points.
    bearing: func(x1: f64, y1: f64, x2: f64, y2: f64) -> f64;
    distance: func(x1: f64, y1: f64, x2: f64, y2: f64) -> f64;
    /// Smallest signed angular difference between two bearings (radians).
    angular-diff: func(b1: f64, b2: f64) -> f64;
}

interface other-indexes-ops {
    use types.{timestamp-tz};

    /// 2D point with an associated identifier — the unit of bulk-load for
    /// quadtree/kdtree2d query helpers.
    record indexed-point-xy { x: f64, y: f64, id: s64 }
    /// 3D point with an associated identifier — for octree/kdtree3d helpers.
    record indexed-point-xyz { x: f64, y: f64, z: f64, id: s64 }
    /// Interval with an identifier — for interval-tree helpers.
    record indexed-interval { start: s64, end: s64, id: s64 }

    /// Build a quadtree over the provided 2D points and return ids of points
    /// inside the [min_x, max_x] × [min_y, max_y] bounding box.
    quadtree-query-box: func(
        points: list<indexed-point-xy>,
        min-x: f64, min-y: f64, max-x: f64, max-y: f64,
    ) -> list<s64>;

    /// Build a 2D kd-tree and return the k nearest ids to (qx, qy).
    kdtree-xy-nearest-k: func(
        points: list<indexed-point-xy>, qx: f64, qy: f64, k: u32,
    ) -> list<s64>;

    /// Build a 2D kd-tree and return ids within `distance` of (qx, qy).
    kdtree-xy-within: func(
        points: list<indexed-point-xy>, qx: f64, qy: f64, distance: f64,
    ) -> list<s64>;

    /// Build a 3D kd-tree and return the k nearest ids to (qx, qy, qz).
    kdtree-xyz-nearest-k: func(
        points: list<indexed-point-xyz>, qx: f64, qy: f64, qz: f64, k: u32,
    ) -> list<s64>;

    /// Build a 3D kd-tree and return ids within `distance` of (qx, qy, qz).
    kdtree-xyz-within: func(
        points: list<indexed-point-xyz>, qx: f64, qy: f64, qz: f64, distance: f64,
    ) -> list<s64>;

    /// Build an octree over the provided 3D points and return ids of points
    /// inside the [min, max] cuboid.
    octree-query-box: func(
        points: list<indexed-point-xyz>,
        min-x: f64, min-y: f64, min-z: f64,
        max-x: f64, max-y: f64, max-z: f64,
    ) -> list<s64>;

    /// Build an octree and return ids within the sphere centered at (cx, cy, cz).
    octree-query-sphere: func(
        points: list<indexed-point-xyz>, cx: f64, cy: f64, cz: f64, radius: f64,
    ) -> list<s64>;

    /// Build an interval tree and return ids of intervals containing `ts`.
    interval-tree-query-point: func(intervals: list<indexed-interval>, ts: timestamp-tz) -> list<s64>;

    /// Build an interval tree and return ids of intervals overlapping [start, end].
    interval-tree-query-overlapping: func(intervals: list<indexed-interval>, start: s64, end: s64) -> list<s64>;
}

interface tnpoint-ops {
    use types.{timestamp-tz, time-period, temporal-error};

    record npoint { route-id: s64, position: f64 }
    record nsegment { route-id: s64, start-pos: f64, end-pos: f64 }
    record tnpoint-instant { timestamp: timestamp-tz, point: npoint }
    record tnpoint-sequence {
        instants: list<tnpoint-instant>,
        lower-inclusive: bool,
        upper-inclusive: bool,
    }

    npoint-new: func(route-id: s64, position: f64) -> npoint;
    npoint-distance: func(a: npoint, b: npoint) -> option<f64>;
    npoint-same-route: func(a: npoint, b: npoint) -> bool;

    nsegment-new: func(route-id: s64, start-pos: f64, end-pos: f64) -> result<nsegment, temporal-error>;
    nsegment-length: func(s: nsegment) -> f64;
    nsegment-contains: func(s: nsegment, p: npoint) -> bool;
    nsegment-overlaps: func(a: nsegment, b: nsegment) -> bool;
    nsegment-midpoint: func(s: nsegment) -> npoint;

    tnpoint-instant-new: func(t: timestamp-tz, route-id: s64, position: f64) -> tnpoint-instant;
    tnpoint-sequence-new: func(instants: list<tnpoint-instant>) -> result<tnpoint-sequence, temporal-error>;
    tnpoint-num-instants: func(seq: tnpoint-sequence) -> u32;
    tnpoint-route-id: func(seq: tnpoint-sequence) -> option<s64>;
    tnpoint-is-single-route: func(seq: tnpoint-sequence) -> bool;
    tnpoint-network-length: func(seq: tnpoint-sequence) -> f64;
    tnpoint-start-position: func(seq: tnpoint-sequence) -> option<f64>;
    tnpoint-end-position: func(seq: tnpoint-sequence) -> option<f64>;
    tnpoint-position-at: func(seq: tnpoint-sequence, t: timestamp-tz) -> option<f64>;
    tnpoint-is-forward: func(seq: tnpoint-sequence) -> bool;
    tnpoint-is-backward: func(seq: tnpoint-sequence) -> bool;
    tnpoint-avg-network-speed: func(seq: tnpoint-sequence) -> option<f64>;
    tnpoint-min-position: func(seq: tnpoint-sequence) -> option<f64>;
    tnpoint-max-position: func(seq: tnpoint-sequence) -> option<f64>;
    tnpoint-time-span: func(seq: tnpoint-sequence) -> option<time-period>;

    // ---- Z2: EWKT codecs ----
    tnpoint-to-ewkt:    func(seq: tnpoint-sequence) -> string;
    tnpoint-from-ewkt:  func(s: string) -> option<tnpoint-sequence>;
}

interface bitemporal-bool-ops {
    use types.{timestamp-tz, time-period, temporal-error};

    record bitemporal-bool-instant {
        value: bool,
        valid-start: s64,
        valid-end: s64,
        transaction-start: s64,
        transaction-end: s64,
    }
    record bitemporal-bool-sequence {
        instants: list<bitemporal-bool-instant>,
    }

    bitemporal-bool-instant-new: func(value: bool, valid-start: s64, valid-end: s64, transaction-start: s64, transaction-end: s64) -> bitemporal-bool-instant;
    bitemporal-bool-sequence-new: func(instants: list<bitemporal-bool-instant>) -> bitemporal-bool-sequence;
    bitemporal-bool-len: func(seq: bitemporal-bool-sequence) -> u32;

    bitemporal-bool-valid-at: func(seq: bitemporal-bool-sequence, valid-ts: s64) -> option<bool>;
    bitemporal-bool-as-of: func(seq: bitemporal-bool-sequence, valid-ts: s64, transaction-ts: s64) -> option<bool>;
    bitemporal-bool-count-current: func(seq: bitemporal-bool-sequence) -> u32;
    bitemporal-bool-count-superseded: func(seq: bitemporal-bool-sequence) -> u32;
    bitemporal-bool-valid-extent: func(seq: bitemporal-bool-sequence) -> option<time-period>;
    bitemporal-bool-transaction-extent: func(seq: bitemporal-bool-sequence) -> option<time-period>;

    /// W7: text codecs.
    bitemporal-bool-to-ewkt:   func(seq: bitemporal-bool-sequence) -> string;
    bitemporal-bool-from-ewkt: func(s: string) -> option<bitemporal-bool-sequence>;
}

interface bitemporal-text-ops {
    use types.{timestamp-tz, time-period, temporal-error};

    record bitemporal-text-instant {
